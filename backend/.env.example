# Server configuration
DEBUG=true

# Security
SECRET_KEY=generate-a-secure-secret-key-here-for-production
HASH_ROUNDS=12

# Database configuration
# For local development with SQLite, use:
DATABASE_URL=sqlite+aiosqlite:///./database.db
# For PostgreSQL with PostGIS, use:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/here

# Cache & Message Queue
REDIS_URL=redis://localhost:6379/0

# Mail server settings (OTP / Account Verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=user@gmail.com
SMTP_PASSWORD=app-specific-password
SMTP_FROM_EMAIL=noreply@here.com

# Timing configurations (defaults match original Rust backend)
OTP_PREFIX=otp:
OTP_EXPIRY_SECONDS=300
VERIFICATION_TOKEN_EXPIRY_SECONDS=600
BLACKLIST_TOKEN_PREFIX=blacklist:
